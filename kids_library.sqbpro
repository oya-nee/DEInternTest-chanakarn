<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="kids_library.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="916"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="kids_books" custom_title="0" dock_id="2" table="4,10:mainkids_books"/><dock_state state="000000ff00000000fd00000001000000020000043c000002b6fc0100000002fb000000160064006f0063006b00420072006f007700730065003101000000000000043c0000000000000000fb000000160064006f0063006b00420072006f00770073006500320100000000ffffffff0000011800ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- ภาพรวมข้อมูล

SELECT
    COUNT(*) AS total_books,
    COUNT(publish_year) AS has_year,
    COUNT(*) - COUNT(publish_year) AS missing_year,
    MIN(publish_year) AS oldest,
    MAX(publish_year) AS newest
FROM kids_books;


-- หนังสือใหม่สุด 20 เล่ม
SELECT id, book_title, publish_year
FROM kids_books
WHERE publish_year IS NOT NULL
ORDER BY publish_year DESC
LIMIT 20;


-- จำนวนหนังสือแยกตามปี (30 ปีล่าสุด)
SELECT publish_year, COUNT(*) AS total
FROM kids_books
WHERE publish_year &gt;= 1994
GROUP BY publish_year
ORDER BY publish_year DESC;


-- ค้นหาจากชื่อ 
SELECT id, book_title, publish_year
FROM kids_books
WHERE book_title LIKE '%Harry%'
ORDER BY publish_year DESC;


-- ชื่อยาวสุด 10 อันดับ
SELECT book_title, LENGTH(book_title) AS len, publish_year
FROM kids_books
ORDER BY len DESC
LIMIT 10;


-- จำนวนหนังสือแยกตามปี
SELECT
    CASE
        WHEN publish_year &lt; 1900 THEN 'Before 1900'
        WHEN publish_year &lt; 1950 THEN '1900-1949'
        WHEN publish_year &lt; 1980 THEN '1950-1979'
        WHEN publish_year &lt; 2000 THEN '1980-1999'
        WHEN publish_year &lt; 2010 THEN '2000-2009'
        ELSE'2010-present'
    END AS r,
    COUNT(*) AS total
FROM kids_books
WHERE publish_year IS NOT NULL
GROUP BY r
ORDER BY MIN(publish_year);


-- duplicate check 
SELECT book_title, COUNT(*) AS cnt
FROM kids_books
GROUP BY book_title
HAVING cnt &gt; 1;


-- null check
SELECT
    SUM(CASE WHEN book_title IS NULL OR book_title = '' THEN 1 ELSE 0 END) AS missing_title,
    SUM(CASE WHEN publish_year IS NULL THEN 1 ELSE 0 END) AS missing_year,
    SUM(CASE WHEN extracted_at IS NULL THEN 1 ELSE 0 END) AS missing_ts
FROM kids_books;</sql><current_tab id="0"/></tab_sql></sqlb_project>